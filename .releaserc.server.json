{
  "branches": [
    {
      "name": "stable-services",
      "channel": "stable"
    },
    {
      "name": "newjitsu",
      "channel": "beta",
      "prerelease": "beta"
    },
    {
      "name": "*",
      "channel": "canary",
      "prerelease": "canary"
    }
  ],
  "tagFormat": "jitsu-services-v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/changelog",
    [
      "@semantic-release/exec",
      {
        "verifyReleaseCmd": "CHANNEL=${nextRelease.channel}; VERSION=${nextRelease.version}; if [ \"$CHANNEL\" = \"canary\" ]; then TIMESTAMP=$(date -u +%Y%m%d%H%M%S); SHORT_SHA=$(git rev-parse --short=7 HEAD); VERSION=\"${VERSION}.${TIMESTAMP}.${SHORT_SHA}\"; fi; echo \"$VERSION\" > /tmp/semantic-release-version.txt"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md"],
        "message": "chore(release): jitsu-services ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
