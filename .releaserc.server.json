{
  "branches": [
    {
      "name": "stable-services",
      "channel": "stable"
    },
    {
      "name": "newjitsu",
      "channel": "beta",
      "prerelease": "beta"
    }
  ],
  "tagFormat": "jitsu-services-v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "verifyReleaseCmd": "echo ${nextRelease.version} > /tmp/semantic-release-version.txt"
      }
    ],
    "@semantic-release/github"
  ]
}
