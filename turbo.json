{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.local", "tsconfig.json", "package.json"],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "compiled/**", "build/**", ".next/**", "!.next/cache/**"],
      "inputs": [
        "src/**",
        "lib/**",
        "pages/**",
        "components/**",
        "styles/**",
        "public/**",
        "prisma/**",
        "package.json",
        "tsconfig.json",
        "*.config.js",
        "*.config.ts"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "lib/**", "__tests__/**", "*.config.js", "*.config.ts"]
    },
    "test:playwright": {
      "dependsOn": ["^build"],
      "outputs": ["playwright/artifacts/**"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["src/**", "lib/**", "pages/**", "components/**", ".eslintrc*", "*.config.js"]
    },
    "clean": {
      "cache": false
    },
    "console:dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "console:start": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "console:storybook": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "ee-api:dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "rotor:dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "profiles:dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "tool:hash": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
