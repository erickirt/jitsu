    "node-sql-parser": "^5.3.13",
    "@confluentinc/kafka-javascript": "^1.9.0",
    "@jitsu/destination-functions": "workspace:*",
    "@jitsu/core-functions-lib": "workspace:*",
    "@jitsu/functions-lib": "workspace:*",
    "@maxmind/geoip2-node": "^5.0.0",
    "@types/pg-cursor": "^2.7.2",
