{
  "name": "@jitsu-internal/profile-builder",
  "version": "0.0.0",
  "description": "",
  "author": "Jitsu Dev Team <dev@jitsu.com>",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "private": false,
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "build": "tsx build.mts",
    "start": "dotenv -e ../../.env.local -- node dist/main.js",
    "profiles:dev": "tsx --env-file=../../.env --env-file=../../.env.local --watch src/index.ts",
    "profiles:profile": "tsx --env-file=../../.env --env-file=../../.env.local --watch --inspect src/index.ts"
  },
  "dependencies": {
    "mongodb": "^6.16.0",
    "isolated-vm": "6.0.0",
    "@jitsu/core-functions": "workspace:*",
    "@jitsu/functions-lib": "workspace:*",
    "juava": "workspace:*",
    "node-cache": "^5.1.2",
    "p-queue": "^6.6.2",
    "express": "^4.21.2",
    "pg": "~8.11.6",
    "pg-cursor": "^2.11.0",
    "prom-client": "^15.1.3",
    "tslib": "catalog:",
    "@confluentinc/kafka-javascript": "^1.4.1",
    "@clickhouse/client": "^1.10.1"
  },
  "devDependencies": {
    "@jitsu/common-config": "workspace:*",
    "@jitsu/protocols": "workspace:*",
    "@swc-node/register": "catalog:",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "~8.11.15",
    "@types/pg-cursor": "^2.7.2",
    "@types/web": "^0.0.152",
    "@types/express": "^4.17.21",
    "@vitest/ui": "catalog:",
    "dotenv-cli": "^7.4.2",
    "esbuild": "^0.24.2",
    "lodash": "catalog:",
    "nodemon": "^3.1.4",
    "ts-node": "catalog:",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
