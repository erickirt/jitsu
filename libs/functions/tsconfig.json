{
  "extends": "@jitsu/common-config/tsconfig.json",
  "compilerOptions": {
    "lib": ["dom", "esnext"],
    "rootDir": "./src",
    "strict": true,
    "outDir": "./dist",
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "__tests__",
    "dist",
    "test_projects",
    "test",
    "templates"
  ]
}
