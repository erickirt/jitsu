      "optional": true
    }
  },
  "devDependencies": {
    "@jitsu/common-config": "workspace:*",
    "ts-toolbelt": "^9.6.0",
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^29.2.3",
    "@types/node": "catalog:",
