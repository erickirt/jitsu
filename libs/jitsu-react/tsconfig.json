{
  "extends": "@jitsu/common-config/tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "lib": ["dom", "esnext"],
    "jsx": "react",
    "sourceMap": true,
    "declaration": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["src"],
  "exclude": ["dist"]
}
