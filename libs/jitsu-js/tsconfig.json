{
  "extends": "@jitsu/common-config/tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./compiled",
    "declaration": true,
    "target": "ES2015",
    "lib": ["dom", "esnext"],
    //this makes typescript igore @types/node during compilation
    "types": [],
    "strictNullChecks": false,
    "noImplicitThis": false,
    "useUnknownInCatchVariables": false
  },
  "include": ["./src", "./__tests__"],
  "exclude": [
    "__tests__",
    "dist",
    "test_projects",
    "test",
    "templates"
  ]
}