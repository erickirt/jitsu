{
  "extends": "@jitsu/common-config/tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "declaration": true,
    "target": "ES2015",
    "lib": ["dom", "esnext"],
    //this makes typescript igore @types/node during compilation
    "emitDeclarationOnly": true,
    "types": [],
    "isolatedModules": true,
    "useUnknownInCatchVariables": false
  },
  "include": ["./src", "./__tests__"],
  "exclude": [
    "__tests__",
    "dist",
    "test_projects",
    "test",
    "templates"
  ]
}