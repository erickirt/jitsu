{
  "extends": "@jitsu/common-config/tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "noEmit": true,
    "strictNullChecks": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "__tests__",
    "dist",
    "test_projects",
    "test",
    "templates"
  ]
}