{
  "name": "root",
  "version": "0.0.0",
  "private": false,
  "license": "MIT",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "codegen": "pnpm --filter @jitsu-internal/console prisma generate",
    "format:check": "prettier --ignore-unknown --check --config ./.prettierrc.json --ignore-path ./.prettierignore $(git diff --name-only --diff-filter d | xargs)",
    "format:check:all": "prettier --check --config ./.prettierrc.json --ignore-path ./.prettierignore .",
    "format": "prettier --ignore-unknown --write --config ./.prettierrc.json --ignore-path ./.prettierignore $(git diff --name-only --diff-filter d | xargs)",
    "format:all": "prettier --write --config ./.prettierrc.json --ignore-path ./.prettierignore .",
    "format:staged": "sh scripts/format-staged.sh",
    "prepare": "husky install",
    "pre-commit": "pnpm format:staged",
    "build:turbo": "turbo run build",
    "build": "pnpm -r run build",
    "typecheck:turbo": "turbo run typecheck",
    "typecheck": "pnpm -r run typecheck",
    "console:dev": "pnpm --filter console console:dev",
    "ui:dev": "turbo run console:dev",
    "console:manage": "pnpm --filter console manage",
    "rotor:dev": "pnpm --filter rotor rotor:dev",
    "tool:hash": "pnpm --filter console run tool:hash",
    "ci:no-test": "pnpm format:check:all && pnpm lint && pnpm build",
    "ci:all": "pnpm ci:no-test && pnpm test",
    "console:start": "turbo run console:start",
    "console:db-prepare": "pnpm run --filter=console db:update-schema",
    "console:db-prepare-force": "pnpm run --filter=console db:update-schema-force",
    "dev": "pnpm --filter @jitsu-internal/dev-scripts run --silent exec --",
    "test": "pnpm -r run test",
    "test:playwright": "pnpm -r run test:playwright",
    "cli": "pnpm --filter jitsu-cli --silent run cli",
    "factory-reset": "pnpm clean ; pnpm clean:turbo ; rm -rf `find . -type d -name node_modules`",
    "clean:turbo": "turbo run clean || exit 0",
    "clean": "pnpm -r run clean",
    "lint": "pnpm -r run lint"
  },
  "devDependencies": {
    "env-preload": "workspace:*",
    "@playwright/test": "1.58.2",
    "husky": "^8.0.3",
    "portless": "^0.12.0",
    "prettier": "^2.8.7",
    "turbo": "^2.9.14",
    "typescript": "catalog:"
  },
  "engines": {
    "yarn": ">=1000",
    "pnpm": ">=9",
    "npm": ">=1000",
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "lodash@<4.18.1": "^4.18.1",
      "axios@<1.15.2": "^1.15.2",
      "handlebars@<4.7.9": "^4.7.9",
      "fast-xml-parser@<5.7.0": "^5.7.0",
      "fast-xml-builder@<1.1.7": "^1.1.7",
      "fast-uri@<3.1.2": "^3.1.2",
      "tar-fs@<2.1.4": "^2.1.4",
      "flatted@<3.4.2": "^3.4.2",
      "minimatch@9.0.1": "^9.0.9",
      "socket.io-parser@<4.2.6": "^4.2.6",
      "form-data@<4.0.4": "^4.0.4",
      "zstd-napi@<0.0.10": "^0.0.10",
      "nth-check@<2.1.1": "2.1.1",
      "nanoid@<3.3.8": "3.3.8",
      "postcss@<8.5.10": "^8.5.10",
      "uuid@<14.0.0": "^14.0.0",
      "cross-spawn@<7.0.6": "^7.0.6",
    "path-to-regexp@<0.1.13": "^0.1.13",
    "follow-redirects@<1.16.0": "^1.16.0",
    "@types/react": "18.3.0",
      "@types/react-dom": "18.3.1",
      "glob@>=10.2.0 <10.5.0": "^10.5.0",
      "qs@<6.15.2": "^6.15.2",
      "next@<16.2.3": "^16.2.3",
      "@tootallnate/once@<3.0.1": "^3.0.1",
      "protobufjs@<7.5.6": "^7.5.6",
      "@protobufjs/utf8@<1.1.1": "^1.1.1",
      "lodash-es@<4.18.0": "^4.18.0",
      "yaml@<2.8.3": "^2.8.3",
      "picomatch@<2.3.2": "^2.3.2",
      "js-yaml@<3.14.2": "^3.14.2",
      "@babel/runtime@<7.26.10": "^7.26.10",
      "@babel/helpers@<7.26.10": "^7.26.10",
      "tmp@<0.2.6": "^0.2.6",
      "js-cookie@<3.0.7": "^3.0.7",
      "react-router@<7.15.0": "^7.15.0",
      "ws@<5.2.4": "^5.2.4",
      "ws@>=6 <6.2.3": "^6.2.3",
      "ws@>=7 <7.5.10": "^7.5.10",
      "ws@>=8 <8.20.1": "^8.20.1",
      "brace-expansion@<1.1.12": "^1.1.12",
      "brace-expansion@>=2 <2.0.2": "^2.0.2",
      "brace-expansion@>=3 <3.0.1": "^3.0.1",
      "brace-expansion@>=4 <4.0.1": "^4.0.1",
      "brace-expansion@>=5 <5.0.6": "^5.0.6"
    },
    "onlyBuiltDependencies": [
      "@confluentinc/kafka-javascript",
      "@firebase/util",
      "@mongodb-js/zstd",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "core-js",
      "core-js-pure",
      "esbuild",
      "prisma",
      "protobufjs",
      "sharp",
      "turbo",
      "zstd-napi"
    ]
  },
  "workspaces": [
    "examples/*",
    "e2e",
    "types/*",
    "webapps/*",
    "services/*",
    "cli/*",
    "libs/*"
  ]
}
