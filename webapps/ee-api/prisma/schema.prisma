// Prisma schema for ee-api's own tables.
//
// All models live in the `newjitsuee` Postgres schema and are owned by this
// service. The `newjitsu` schema is owned by webapps/console's Prisma — it must
// NOT be added here, or `prisma db push` would try to drop its tables. Read
// `newjitsu` tables through the raw `pg` pool from lib/services.ts instead.
//
// `prisma db push` (run via `pnpm db:update-schema`) manages every table in the
// `newjitsuee` schema and drops anything not modeled below — keep this file in
// sync with the schema's full table list. The models here are introspected to
// match production exactly; `db push` against prod is a no-op.

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["newjitsuee"]
}

/// Key-value store with a hash-map interface, backing lib/store.ts.
model KvRecord {
  id        String
  namespace String
  obj       Json?
  expire    DateTime? @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([id, namespace])
  @@map("kvstore")
  @@schema("newjitsuee")
}

/// Cached per-workspace event and sync counts, refreshed by /api/sync-cache.
model StatCache {
  workspaceId String
  period      DateTime  @db.Timestamp(6)
  events      Decimal   @db.Decimal
  syncs       Decimal   @default(0) @db.Decimal
  /// Data-freshness watermark: how much of `period` the counts cover. End of
  /// day for completed days, the sync run time for the in-progress day. Lets
  /// the UI extrapolate today's partial total. Null on rows cached before this
  /// column was added.
  cutoff      DateTime? @db.Timestamp(6)

  @@id([workspaceId, period], map: "stat_cache_pk")
  @@map("stat_cache")
  @@schema("newjitsuee")
}

/// Stripe overage invoices created for completed billing periods. One row per
/// workspace per period; `period` is `YYYY-MM-DD_YYYY-MM-DD` (start inclusive,
/// end exclusive). Populated from the admin workspaces page (manual create) and
/// backfilled from Stripe — see lib/overage-invoices.ts.
model OverageInvoice {
  workspaceId String   @map("workspace_id")
  period      String
  invoiceId   String   @map("invoice_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([workspaceId, period], map: "overage_invoices_pk")
  @@map("overage_invoices")
  @@schema("newjitsuee")
}

/// DEAD TABLE — modeled here only so `prisma db push` does not drop it.
/// It is a hand-managed table that used to feed the `newjitsu.backup_connections`
/// view. That view has been removed, and S3 backup connections are now built in
/// pages/api/s3-connections.ts straight from the S3_REGION / S3_ACCESS_KEY_ID /
/// S3_SECRET_ACCESS_KEY env vars. Nothing reads this table anymore — it (and
/// this model) should be dropped once that is confirmed in production.
/// `@@ignore`d because the table has no unique identifier.
model TmpS3Credentials {
  s3region    String?
  s3accessKey String?
  s3secretKey String?

  @@map("tmp_s3_credentials")
  @@ignore
  @@schema("newjitsuee")
}

/// Generic key/value sync-state table. Not referenced anywhere in the codebase;
/// modeled here only so `prisma db push` does not drop it.
model SyncState {
  name        String    @id
  value       Json?
  created     DateTime? @default(now()) @db.Timestamp(6)
  lastUpdated DateTime? @default(now()) @map("last_updated") @db.Timestamp(6)

  @@map("sync_state")
  @@schema("newjitsuee")
}
