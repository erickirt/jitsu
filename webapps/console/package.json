  "private": false,
  "scripts": {
    "prisma": "prisma",
    "lint": "next lint",
    "console:dev": "dotenv -e ../../.env.local next dev",
    "console:start": "next start",
    "email:dev": "email dev -p 3901",
    "build": "prisma generate && next build && pnpm build:manage",
    "build:manage": "esbuild scripts/manage.ts --bundle --platform=node --outfile=build/manage.js --external:@prisma/client --external:pg-native",
    "manage": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local scripts/manage.ts",
    "clean": "rm -rf ./.next ./.turbo ./build",
    "typecheck": "tsc --noEmit",
    "tool:hash": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local scripts/manage.ts password-hash",
    "db:code-gen": "prisma generate",
    "db:update-schema": "dotenv -e ../../.env.local -- prisma db push",
    "db:format-schema": "dotenv -e ../../.env.local -- prisma format",
    "db:update-schema-force": "dotenv -e ../../.env.local -- prisma db push --accept-data-loss"
  },
