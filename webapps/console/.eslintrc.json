{
  "extends": "next/core-web-vitals",
  "plugins": [
    "unused-imports"
  ],
  "rules": {
    "no-unused-vars": "off",
    "unused-imports/no-unused-imports": "error",
    "react/jsx-curly-brace-presence": ["off", { "props": "never" }],
//    "unused-imports/no-unused-vars": [
//      "warn",
//      {
//        "vars": "all",
//        "varsIgnorePattern": "^_",
//        "args": "after-used",
//        "argsIgnorePattern": "^_"
//      }
//    ],
    "react/no-unescaped-entities": 0,
    "@next/next/no-img-element": 0,
    "import/no-anonymous-default-export": 0,
    "no-restricted-properties": [
      "error",
      {
        "object": "process",
        "property": "env",
        "message": "Direct access to process.env is not allowed. Use serverEnv from lib/server/serverEnv.ts or clientEnv from lib/shared/clientEnv.ts instead."
      }
    ]
  },
  "overrides": [
    {
      "files": ["lib/server/serverEnv.ts", "lib/shared/clientEnv.ts", "next.config.js"],
      "rules": {
        "no-restricted-properties": "off"
      }
    }
  ]
}
